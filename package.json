{
  "name": "dexera-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Dexera monorepo bootstrap (Next.js-first frontend, Go BFF, Rust services)",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dexera/web dev",
    "dev:all": "turbo run dev --parallel",
    "dev:api:docker": "sh ./scripts/dev-api-compose.sh",
    "dev:api:docker:stubs": "STUBS=1 sh ./scripts/dev-api-compose.sh",
    "dev:api:docker:down": "CMD=down sh ./scripts/dev-api-compose.sh",
    "dev:api:docker:logs": "CMD=logs sh ./scripts/dev-api-compose.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "pnpm codegen:check && pnpm turbo run lint typecheck test build --continue",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen-check.mjs",
    "contracts:validate": "node scripts/validate-contracts.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
