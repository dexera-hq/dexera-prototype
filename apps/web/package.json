{
  "name": "@dexera/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:test": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@dexera/api-types": "workspace:*",
    "@dexera/shared-types": "workspace:*",
    "next": "^15.5.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@dexera/eslint-config": "workspace:*",
    "@dexera/tsconfig": "workspace:*"
  }
}
