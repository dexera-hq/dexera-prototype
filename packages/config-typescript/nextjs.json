{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": false,
    "incremental": true,
    "isolatedModules": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "lib": ["DOM", "DOM.Iterable", "ES2023"]
  },
  "exclude": ["node_modules"]
}
