{
  "name": "@dexera/portfolio-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cargo run --manifest-path Cargo.toml",
    "build": "cargo build --manifest-path Cargo.toml",
    "lint": "cargo fmt --manifest-path Cargo.toml --all -- --check && cargo clippy --manifest-path Cargo.toml --all-targets -- -D warnings",
    "format": "cargo fmt --manifest-path Cargo.toml --all",
    "typecheck": "cargo check --manifest-path Cargo.toml",
    "test": "cargo test --manifest-path Cargo.toml"
  }
}
